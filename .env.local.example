# Required — Supabase project credentials
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Required for AI Coach Insights (server-side only)
ANTHROPIC_API_KEY=

# Optional — read-only demo mode (middleware lets unauthenticated traffic through)
# NEXT_PUBLIC_DEMO_MODE=false
# NEXT_PUBLIC_DEMO_USER_ID=

# Optional — Splunk HEC logging for /api/log
# SPLUNK_URL=
# SPLUNK_HEC_TOKEN=
# Dev only: allow self-signed Splunk certs
# SPLUNK_ALLOW_SELF_SIGNED=false
