# Required — Supabase project credentials
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Required for AI Coach Insights (server-side only)
ANTHROPIC_API_KEY=

# Optional — read-only public demo. When true, logged-out visitors browse the
# seeded demo account (read-only via demo-public RLS) instead of being sent to
# login. Real users still log in and see their own data. Set BOTH to enable.
# NEXT_PUBLIC_DEMO_MODE=true
# NEXT_PUBLIC_DEMO_USER_ID=581543c1-a23a-4f95-a7ed-c98fb285ece7

# Optional — Fitbit connector via the Google Health API (Fitbit Web API successor).
# All server-side only. Create a Google Cloud project, enable the Google Health
# API, configure the OAuth consent screen (Testing), and make a "Web application"
# OAuth client. Scope: googlehealth.activity_and_fitness.readonly
# GOOGLE_HEALTH_CLIENT_ID=
# GOOGLE_HEALTH_CLIENT_SECRET=
# GOOGLE_HEALTH_REDIRECT_URI=https://redjitsu.vercel.app/api/fitbit/callback
# 32-byte base64 key for encrypting OAuth tokens at rest:  openssl rand -base64 32
# TOKEN_ENC_KEY=
# Service role key (used ONLY by the daily sync cron — never client-exposed):
# SUPABASE_SERVICE_ROLE_KEY=
# Secret that authorizes the Vercel Cron call:  openssl rand -hex 32
# CRON_SECRET=

# Optional — Splunk HEC logging for /api/log
# SPLUNK_URL=
# SPLUNK_HEC_TOKEN=
# Dev only: allow self-signed Splunk certs
# SPLUNK_ALLOW_SELF_SIGNED=false
