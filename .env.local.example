# Required — Supabase project credentials
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Required for AI Coach Insights (server-side only)
ANTHROPIC_API_KEY=

# Optional — read-only public demo. When true, logged-out visitors browse the
# seeded demo account (read-only via demo-public RLS) instead of being sent to
# login. Real users still log in and see their own data. Set BOTH to enable.
# NEXT_PUBLIC_DEMO_MODE=true
# NEXT_PUBLIC_DEMO_USER_ID=581543c1-a23a-4f95-a7ed-c98fb285ece7

# Optional — Splunk HEC logging for /api/log
# SPLUNK_URL=
# SPLUNK_HEC_TOKEN=
# Dev only: allow self-signed Splunk certs
# SPLUNK_ALLOW_SELF_SIGNED=false
